# Application identity and runtime mode.
# APP_ENV: local / staging / production
# APP_URL: the public URL users will access, e.g. https://crm.example.com
APP_NAME='Krayin CRM'
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Kolkata
APP_LOCALE=en
APP_CURRENCY=USD

# Reverse proxy and TLS companion settings for docker/nginx-proxy.
# DOMAIN_NAME: public hostname routed by nginx-proxy
# VIRTUAL_NETWORK: shared Docker network name used by nginx-proxy
# LETSENCRYPT_EMAIL: contact email for certificate issuance
DOMAIN_NAME=crm.example.com
VIRTUAL_NETWORK=nginx-proxy
LETSENCRYPT_EMAIL=ops@example.com

# Optional Vite dev server override. Leave blank unless you run Vite separately.
# Example: VITE_HOST=0.0.0.0, VITE_PORT=5173
VITE_HOST=
VITE_PORT=

# Application log level. Typical values: debug, info, warning, error
LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database settings used by both Laravel and the MySQL container.
# For Docker compose, keep DB_HOST=db unless you connect to an external database service.
# DB_ROOT_PASSWORD is only for the MySQL root account inside the container.
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=krayin
DB_USERNAME=krayin
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root
DB_PREFIX=

# Core Laravel runtime drivers.
# Common production values:
# CACHE_DRIVER=file or redis
# QUEUE_CONNECTION=sync or database or redis
# SESSION_DRIVER=file or redis
BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Memcached host if you enable Memcached-backed cache/session storage.
MEMCACHED_HOST=127.0.0.1

# Redis host if you switch cache, queue, or session drivers to redis.
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Outbound email settings.
# Local example: MAIL_HOST=mailhog, MAIL_PORT=1025
# SMTP example: MAIL_HOST=smtp.mailgun.org, MAIL_PORT=587, MAIL_ENCRYPTION=tls
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=laravel@krayincrm.com
MAIL_FROM_NAME="${APP_NAME}"
MAIL_DOMAIN=webkul.com

# Incoming email parsing driver. Example values depend on your integration, e.g. sendgrid
MAIL_RECEIVER_DRIVER=sendgrid

# IMAP inbox settings used when syncing or parsing mailbox content.
# Example provider values:
# Gmail IMAP: IMAP_HOST=imap.gmail.com, IMAP_PORT=993, IMAP_ENCRYPTION=ssl
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_ENCRYPTION=ssl
IMAP_VALIDATE_CERT=true
IMAP_USERNAME=your_username
IMAP_PASSWORD=your_password

# S3-compatible object storage settings.
# Example: AWS_DEFAULT_REGION=ap-southeast-1, AWS_BUCKET=crm-assets
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

# Realtime / websocket integration settings.
# Leave blank unless your deployment uses Pusher-compatible broadcasting.
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
